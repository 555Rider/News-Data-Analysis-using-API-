import pandas as pd
import requests
import time
API_KEY="AnkdEIAYoDeGjuOVj5ft91DySAGODneW"
Full_url = "https://api.nytimes.com/svc/search/v2/articlesearch.json"
urllist=[]
for i in range(1, 12):
    url = f"{Full_url}?q=election&from_date=2021-01-01&api-key={API_KEY}&page={i}"
    urllist.append(url)
print("Generated URLs:\n" + "\n".join(urllist))
def fetch_json(url):
    try:
        response=requests.get(url)
        response.raise_for_status()
        return response.json()
    except requests.RequestException as e:
        print(f"Error fetching data from {url}: {e}")
        return None
info=[]
for url in urllist:
    data = fetch_json(url)
    if data:
        info.append(data)
    time.sleep(10)
finallist=[]
try:
    for page_data in info:
        for result in page_data['response']['docs']:
            value={
                "webTitle":result['headline']['main'],
                "sectionName": result.get('section_name','Unknow'),
                "publishedDate": result['pub_date']}
            finallist.append(value)
except (IndexError, KeyError) as e:
    print(f"Error processing data: {e}")
print(finallist)
articles_df=pd.DataFrame(finallist)
print(articles_df.head())
excel_file_name = "nytimes_articles1.xlsx"
try:
    articles_df.to_excel(excel_file_name, index=False)
    print(f"Data successfully saved to {excel_file_name}")
except Exception as e:
    print(f"Error saving to Excel: {e}")
from IPython.display import HTML
download_link = f'<a href="{excel_file_name}" download>Click here to download the Excel file</a>'
HTML(download_link)
